# ============================================================
# AEGIS — Variables d'environnement
# Copier en .env et remplir toutes les valeurs
# ⚠️  Jamais committer .env
# ============================================================

# ── Base ────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://app.aegis.io
PORT=3000

# ── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/aegis?search_path=public,analytics,ops
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=CHANGE_ME   # généré : openssl rand -hex 32

# ── Vault (chiffrement tokens en DB) ───────────────────────
VAULT_KEY=CHANGE_ME            # 32+ chars : openssl rand -hex 32

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME           # openssl rand -hex 64
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Admin bootstrap ─────────────────────────────────────────
ADMIN_EMAIL=jonathanlamessi@yahoo.fr

# ── LLM (toutes générations UGC, copy, offers...) ─────────
# LLM_API_KEY is deprecated — use ANTHROPIC_API_KEY
# LLM_API_KEY=sk-ant-...         # Anthropic Claude

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Meta Ads ────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=             # Meta Ad Library (gratuit)

# ── TikTok Ads ──────────────────────────────────────────────
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_CREATIVE_API_KEY=       # TikTok Business API

# ── Shopify ─────────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ── Market Intel — niveau 3 (optionnel niveau 1/2) ─────────
SERPAPI_KEY=                   # Google Trends (~50$/mois)
RAINFOREST_API_KEY=            # Amazon data (~50$/mois)
RAPIDAPI_KEY=                  # TikTok hashtags + divers
SCRAPINGBEE_KEY=               # Scraping concurrents (~49$/mois)

# ── Génération créative (optionnel) ─────────────────────────
REPLICATE_API_KEY=
RUNWAYML_API_KEY=

# ── Scraper Service (Crawl4AI) ─────────────────────────────
SCRAPER_SERVICE_URL=http://localhost:3001
INTERNAL_SERVICE_TOKEN=aegis-internal

# ── Workers ─────────────────────────────────────────────────
WORKER_CONCURRENCY=4
WORKER_HEARTBEAT_MS=15000
WORKER_CLAIM_INTERVAL_MS=1000

# ── Redis (optionnel — rate limiting, cache) ─────────────────
REDIS_URL=redis://redis:6379

# ── CAPI Relay (nouvelles variables) ────────────────────────
META_ADS_TOKEN=             # Meta CAPI access token
TIKTOK_ADS_TOKEN=           # TikTok Events API token
GOOGLE_ADS_DEVELOPER_TOKEN= # Google Enhanced Conversions
PINTEREST_TOKEN=            # Pinterest CAPI token
PINTEREST_AD_ACCOUNT_ID=    # Pinterest Ad Account ID

# ── Social & Market Intel ────────────────────────────────────
TWITTER_BEARER_TOKEN=       # Twitter/X Research API
REDDIT_TOKEN=               # Reddit OAuth token
TIKTOK_RESEARCH_TOKEN=      # TikTok Research API
IG_USER_ID=                 # Instagram Business Account ID
SNAPCHAT_ADS_TOKEN=         # Snapchat Ads API
LINKEDIN_TOKEN=             # LinkedIn API token
PINTEREST_TOKEN=            # Pinterest API token
EXPLODING_TOPICS_KEY=       # Exploding Topics API

# ── LLM (alias) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...   # Alias de LLM_API_KEY (les deux supportés)

# ── Auth ─────────────────────────────────────────────────────
JWT_REFRESH_SECRET=CHANGE_ME   # openssl rand -hex 64 (différent de JWT_SECRET)

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info                 # debug | info | warn | error

# ── Media / Storage ─────────────────────────────────────────
MEDIA_STORAGE_BUCKET=aegis-media
MEDIA_CDN_URL=https://cdn.aegis.io

# ── Supabase (si utilisé) ─────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Webhooks ─────────────────────────────────────────────────
AEGIS_WEBHOOK_BASE_URL=https://app.aegis.io
NEXT_PUBLIC_APP_URL=https://app.aegis.io

# ── Meta Ads (avancé) ─────────────────────────────────────
META_TEST_EVENT_CODE=           # Code test CAPI (optionnel, staging seulement)

# ── Sources Intel niveau 3 ────────────────────────────────
RAPIDAPI_TIKTOK_KEY=            # TikTok Research via RapidAPI
SIMILARWEB_API_KEY=             # SimilarWeb Traffic API
YOUTUBE_API_KEY=                # YouTube Data API v3
APIFY_KEY=                      # Apify scraping actors
DATAFORSEO_KEY=                 # DataForSEO SERP API

# ── PWA Push Notifications (v4.2) ─────────────────────────────
# Generate with: make vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
