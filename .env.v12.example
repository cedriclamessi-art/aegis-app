# ============================================================
# AEGIS v12.3 — Variables d'Environnement
# Copier ce fichier vers .env et remplir les valeurs
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- Base de Données PostgreSQL ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/aegis_db

# --- Redis Cache ---
REDIS_URL=redis://localhost:6379

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# --- OpenAI ---
OPENAI_API_KEY=sk-xxx

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Shopify ---
SHOPIFY_API_KEY=xxx
SHOPIFY_API_SECRET=xxx
SHOPIFY_APP_URL=https://xxx.ngrok.io

# --- Meta Ads ---
META_APP_ID=xxx
META_APP_SECRET=xxx
META_ACCESS_TOKEN=xxx

# --- TikTok Ads ---
TIKTOK_APP_ID=xxx
TIKTOK_APP_SECRET=xxx
TIKTOK_ACCESS_TOKEN=xxx

# --- Google Ads ---
GOOGLE_ADS_CLIENT_ID=xxx
GOOGLE_ADS_CLIENT_SECRET=xxx
GOOGLE_ADS_DEVELOPER_TOKEN=xxx
GOOGLE_ADS_REFRESH_TOKEN=xxx

# --- Pinterest Ads ---
PINTEREST_APP_ID=xxx
PINTEREST_APP_SECRET=xxx
PINTEREST_ACCESS_TOKEN=xxx

# --- Amazon Ads ---
AMAZON_CLIENT_ID=xxx
AMAZON_CLIENT_SECRET=xxx
AMAZON_REFRESH_TOKEN=xxx

# --- Logistique Partenaire ---
LOGISTICS_API_KEY=xxx
LOGISTICS_API_URL=https://api.logistics-partner.com

# --- Email ---
SENDGRID_API_KEY=SG.xxx
FROM_EMAIL=no-reply@aegis.app

# --- Super Admins ---
SUPER_ADMIN_EMAILS=jonathanlamessi@yahoo.fr,admin@aegis.app

# --- Monitoring ---
SENTRY_DSN=https://xxx@sentry.io/xxx

# --- JWT ---
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_EXPIRES_IN=7d
