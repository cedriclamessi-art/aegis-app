{
  "name": "aegis-backend",
  "version": "12.3.0",
  "description": "AEGIS v12.3 Backend — 225 Agents IA • CRO-Optimized • Multi-Marques",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/boot.ts",
    "build": "tsc",
    "start": "node dist/boot.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "monday-flow-worker": "node dist/workers/monday-flow.js",
    "ghost-worker": "node dist/workers/ghost.js",
    "turbulence-worker": "node dist/workers/turbulence.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.0",
    "events": "^3.3.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "otplib": "^12.0.1",
    "pg": "^8.11.5",
    "pino": "^8.21.0",
    "pino-http": "^9.0.0",
    "stripe": "^15.7.0",
    "winston": "^3.11.0",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.5",
    "@types/ws": "^8.18.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
